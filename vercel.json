{
  "version": 2,
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/app/main.py" },
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/home", "dest": "/frontend/home.html" },
    { "src": "/register", "dest": "/frontend/register.html" },
    { "src": "/tutor", "dest": "/frontend/tutor.html" },
    { "src": "/progress", "dest": "/frontend/progress.html" },
    { "src": "/admin", "dest": "/frontend/admin.html" },
    { "src": "/(.*\\.html)", "dest": "/frontend/$1" },
    { "src": "/css/(.*)", "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/frontend/js/$1" }
  ]
}
