# ============================================================
# EduTutor BD — Environment Variables
# Copy this to .env for local dev
# Add ALL of these in Vercel → Project Settings → Environment Variables
# ============================================================

# ─── Groq AI (Free — get at console.groq.com) ───────────────
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ─── Google Gemini (For embeddings — free at aistudio.google.com) ──
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# ─── Supabase (free at supabase.com) ─────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=eyJhbGci...YOUR_SERVICE_KEY

# ─── ChromaDB ────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION=nctb_textbooks

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=change-this-to-random-string
